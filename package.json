{
  "name": "aztec-artifacts-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm recursive run build",
    "test": "pnpm -r run test",
    "dev": "pnpm -r run dev",
    "typecheck": "pnpm recursive run typecheck",
    "lint": "biome lint --fix",
    "format": "biome format --fix",
    "check": "biome check --fix",
    "clean": "pnpm recursive run clean ; rm -rf node_modules/*",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --no-frozen-lockfile && pnpm run --filter \"[HEAD]\" docs",
    "publish-packages": "changeset publish",
    "seed": "pnpm --filter @aztec-artifacts/seed seed",
    "seed:artifacts": "pnpm --filter @aztec-artifacts/seed seed:artifacts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
  "dependencies": {
    "@changesets/cli": "^2.29.7"
  }
}
