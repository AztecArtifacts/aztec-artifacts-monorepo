{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "target": "esnext",
    "lib": ["ESNext"],
    "types": ["node"],
    "paths": {
      "@aztec-artifacts/common": ["../common/src/index.ts"],
      "@aztec-artifacts/common/*": ["../common/src/*"],
      "@aztec-artifacts/schema": ["../schema/src/index.ts"],
      "@aztec-artifacts/schema/*": ["../schema/src/*"]
    }
  },
  "references": [
    { "path": "../common" },
    { "path": "../schema" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
