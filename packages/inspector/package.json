{
  "name": "@aztec-artifacts/inspector",
  "version": "0.1.7",
  "description": "Minimal web inspector for the Aztec Artifacts API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules",
    "start": "node ./server.js"
  },
  "dependencies": {
    "@aztec-artifacts/client": "workspace:^",
    "@fastify/static": "^8.0.2",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "fastify": "^5.2.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
