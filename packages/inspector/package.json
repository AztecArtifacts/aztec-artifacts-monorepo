{
  "name": "@aztec-artifacts/inspector",
  "version": "0.1.11",
  "description": "Minimal web inspector for the Aztec Artifacts API",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "http-server dist -p 4173 -c-1 --cors",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@aztec-artifacts/client": "workspace:^",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "http-server": "^14.1.1",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
