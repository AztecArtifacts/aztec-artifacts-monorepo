{
  "name": "@aztec-artifacts/common",
  "version": "0.1.4",
  "description": "Lightweight Aztec codec and serialization helpers shared across API clients and services",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./convert": {
      "types": "./dist/convert.d.ts",
      "default": "./dist/convert.js"
    },
    "./contract-instance": {
      "types": "./dist/contract-instance.d.ts",
      "default": "./dist/contract-instance.js"
    },
    "./artifact": {
      "types": "./dist/artifact.d.ts",
      "default": "./dist/artifact.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "coverage": "vitest --run --coverage",
    "lint": "biome lint --fix",
    "format": "biome format --fix",
    "check": "biome check --fix",
    "clean": "rm -rf ./dist ./node_modules",
    "docs": "typedoc"
  },
  "dependencies": {
    "@aztec/aztec.js": "^2.0.3",
    "@aztec/foundation": "^2.0.3",
    "@aztec/stdlib": "^2.0.3",
    "tslib": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typedoc": "^0.28.13",
    "typedoc-plugin-markdown": "^4.9.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AztecArtifacts/aztec-artifacts-monorepo"
  },
  "license": "Apache-2.0"
}
