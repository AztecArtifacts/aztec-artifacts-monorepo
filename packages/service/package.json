{
  "name": "@aztec-artifacts/service",
  "version": "0.1.7",
  "description": "API server built with TypeScript and Fastify",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "generate": "DATABASE_URL=foo GENERATE_OPENAPI=true tsx src/index.ts",
    "test": "vitest --run",
    "coverage": "vitest --run --coverage",
    "lint": "biome lint --fix",
    "format": "biome format --fix",
    "check": "biome check --fix",
    "clean": "rm -rf ./dist ./node_modules"
  },
  "dependencies": {
    "@aztec-artifacts/common": "workspace:^",
    "@aztec-artifacts/schema": "workspace:^",
    "@aztec/aztec.js": "^2.0.3",
    "@aztec/foundation": "^2.0.3",
    "@aztec/stdlib": "^2.0.3",
    "@fastify/cors": "^11.1.0",
    "@fastify/env": "^5.0.2",
    "@fastify/otel": "^0.9.4",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.64.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.205.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/instrumentation-pg": "^0.58.0",
    "@opentelemetry/instrumentation-pino": "^0.52.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "pino": "^9.11.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5",
    "openapi-typescript": "^7.9.1",
    "pino-pretty": "^13.1.1"
  },
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/AztecArtifacts/aztec-artifacts-monorepo"
  }
}
