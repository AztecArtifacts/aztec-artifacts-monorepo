# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/aztec_artifacts

# Server Configuration
PORT=8080
API_ROUTE_PREFIX=
LOG_LEVEL=info
LOG_PRETTY=false

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=api-service
OTEL_SERVICE_VERSION=0.0.19
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_METRICS_EXPORT_INTERVAL=60000
OTEL_METRICS_EXPORT_TIMEOUT=30000
OTEL_LOG_LEVEL=info
OTEL_ENVIRONMENT=development

# Optional: Disable telemetry components if needed
OTEL_ENABLE_TRACING=true
OTEL_ENABLE_METRICS=true
OTEL_ENABLE_AUTO_INSTRUMENTATION=true

# Grafana Stack Integration
# OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana-agent:4318
# OTEL_EXPORTER_OTLP_HEADERS={"Authorization": "Bearer your-token"}

# Alternative OTLP Collector endpoints:
# For Jaeger: http://localhost:14268/api/traces
# For Zipkin: http://localhost:9411/api/v2/spans
# For Grafana Cloud: https://otlp-gateway-{region}.grafana.net/otlp
