    "/contracts": {
      "post": {
        "summary": "Upload contract instance",
        "tags": [
          "Contracts"
        ],
        "description": "Upload a contract instance and persist its metadata",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "instance": {
                    "type": "object",
                    "properties": {
                      "address": {
                        "description": "Aztec address as hex string",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{64}$"
                      },
                      "version": {
                        "description": "Contract class version",
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 9007199254740991
                      },
                      "salt": {
                        "description": "Salt as hex string",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{64}$"
                      },
                      "deployer": {
                        "description": "Deployer address as hex string",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{64}$"
                      },
                      "currentContractClassId": {
                        "description": "Current contract class ID as hex string",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{64}$"
                      },
                      "originalContractClassId": {
                        "description": "Original contract class ID as hex string",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{64}$"
                      },
                      "initializationHash": {
                        "description": "Initialization hash as hex string",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{64}$"
                      },
                      "publicKeys": {
                        "description": "Public keys as hex string (use PublicKeys.toString() for serialization)",
                        "type": "string",
                        "pattern": "^0x[a-fA-F0-9]{512}$"
                      },
                      "initializationData": {
                        "nullable": true,
                        "type": "object",
                        "properties": {
                          "constructorArtifact": {
                            "nullable": true,
                            "type": "string"
                          },
                          "constructorArgs": {
                            "nullable": true,
                            "type": "array",
                            "items": {}
                          }
                        },
                        "additionalProperties": false
                      }
                    },
                    "required": [
                      "address",
                      "salt",
                      "deployer",
                      "currentContractClassId",
                      "originalContractClassId",
                      "initializationHash",
                      "publicKeys"
                    ],
                    "additionalProperties": false
                  },
                  "artifact": {
                    "type": "string"
                  }
                },
                "required": [
                  "instance"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "address": {
                      "description": "Aztec address as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "currentContractClassId": {
                      "description": "Current contract class ID as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    }
                  },
                  "required": [
                    "address",
                    "currentContractClassId"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "address": {
                      "description": "Aztec address as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "currentContractClassId": {
                      "description": "Current contract class ID as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    }
                  },
                  "required": [
                    "address",
                    "currentContractClassId"
                  ],
