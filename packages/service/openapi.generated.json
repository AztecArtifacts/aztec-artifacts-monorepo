    "/contracts/{address}": {
      "get": {
        "summary": "Get contract instance by address",
        "tags": [
          "Contracts"
        ],
        "description": "Get a contract instance by its address, optionally including artifact data",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "includeArtifact",
            "required": false,
            "description": "Include artifact data in the response (true/false)"
          },
          {
            "schema": {
              "type": "string",
              "pattern": "^0x[a-fA-F0-9]{64}$"
            },
            "in": "path",
            "name": "address",
            "required": true,
            "description": "Aztec address as hex string"
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "number"
                    },
                    "address": {
                      "description": "Aztec address as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "version": {
                      "type": "number"
                    },
                    "salt": {
                      "description": "Salt as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "deployer": {
                      "description": "Deployer address as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "currentContractClassId": {
                      "description": "Current contract class ID as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "originalContractClassId": {
                      "description": "Original contract class ID as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "initializationHash": {
                      "description": "Initialization hash as hex string",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{64}$"
                    },
                    "publicKeys": {
                      "description": "Public keys as concatenated hex string (use PublicKeys.toString() / fromString() for conversion)",
                      "type": "string",
                      "pattern": "^0x[a-fA-F0-9]{512}$"
                    },
                    "initializationData": {
                      "nullable": true,
                      "type": "object",
                      "properties": {
                        "constructorArtifact": {
                          "nullable": true,
                          "type": "string"
                        },
                        "constructorArgs": {
                          "nullable": true,
                          "type": "array",
                          "items": {}
                        }
                      },
                      "additionalProperties": false
                    },
                    "artifact": {
                      "description": "Serialized ContractArtifact as hex string",
                      "type": "string"
                    },
                    "isToken": {
                      "description": "Whether this contract instance is a token contract",
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "address",
                    "version",
                    "salt",
                    "deployer",
                    "currentContractClassId",
                    "originalContractClassId",
                    "initializationHash",
                    "publicKeys"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
